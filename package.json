{
    "name": "@ericcrosson/eslint-config",
    "version": "1.0.4",
    "description": "Yet another eslint-config",
    "homepage": "https://github.com/ericcrosson/eslint-config",
    "bugs": {
        "url": "https://github.com/ericcrosson/eslint-config/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ericcrosson/eslint-config.git"
    },
    "license": "ISC",
    "author": "Eric Crosson <eric.s.crosson@utexas.edu> (https://github.com/EricCrosson)",
    "main": "index.js",
    "files": [
        "index.js"
    ],
    "scripts": {
        "test": "ava -s -v",
        "prettier": "prettier --list-different index.js",
        "prettier:fix": "prettier --write index.js"
    },
    "peerDependencies": {
        "@typescript-eslint/eslint-plugin": "^4.12.0",
        "eslint": "^6.6.0",
        "eslint-plugin-ava": "^10.2.0",
        "eslint-plugin-fp-ts": "^0.2.1",
        "eslint-plugin-security": "^1.4.0"
    },
    "devDependencies": {
        "@types/node": "^14.0.1",
        "ava": "^3.15.0",
        "prettier": "1.19.1",
        "ts-node": "^9.1.1",
        "typescript": "^4.1.3"
    },
    "ava": {
        "timeout": "1 minute",
        "files": [
            "!dist/**/*.d.ts",
            "test/**/test-*.ts"
        ],
        "extensions": [
            "ts"
        ],
        "require": [
            "ts-node/register"
        ]
    },
    "keywords": [
        "eslint",
        "config"
    ],
    "publishConfig": {
        "access": "public"
    }
}
